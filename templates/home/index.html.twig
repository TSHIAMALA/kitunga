        // Load Admin Portal Data
        async function loadAdminPortalData() {
            if (!jwtToken) return;

            try {
                // 1. Dashboard stats
                const statRes = await fetch('/api/admin/dashboard', {
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                const stats = await statRes.json();

                document.getElementById('admin-stat-sales').textContent = numberWithSpaces(stats.totalSales) + " FC";
                document.getElementById('admin-stat-comm-gen').textContent = numberWithSpaces(stats.totalCommissionsGenerated) + " FC";
                document.getElementById('admin-stat-comm-paid').textContent = numberWithSpaces(stats.totalCommissionsPaid) + " FC";
                document.getElementById('admin-stat-orders').textContent = stats.totalOrders;
                document.getElementById('admin-stat-clients').textContent = stats.totalClients;

                // 2. Fetch clients to look for orders
                const clientsRes = await fetch('/api/admin/clients', {
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                const clients = await clientsRes.json();

                // 3. Fetch all orders
                const ordersRes = await fetch('/api/admin/orders', {
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                const orders = await ordersRes.json();
                renderAdminOrders(orders);

            } catch (err) {
                console.error(err);
                showToast("Erreur Admin", "Impossible de charger les données admin", true);
            }
        }

        // Render admin orders
        function renderAdminOrders(orders) {
            const table = document.getElementById('admin-orders-table');
            if (orders.length === 0) {
                table.innerHTML = `<tr><td colspan="6" class="py-8 text-center text-slate-500">Aucune commande en cours.</td></tr>`;
                return;
            }

            table.innerHTML = orders.map(o => {
                let statusBadge = "";
                let actions = "";

                switch (o.status) {
                    case 'received':
                        statusBadge = `<span class="bg-blue-600/10 text-blue-400 border border-blue-500/20 px-2 py-0.5 rounded-full">reçu</span>`;
                        actions = `<button onclick="updateOrderStatus(${o.id}, 'preparing')" class="px-2.5 py-1 bg-amber-600 hover:bg-amber-500 text-white rounded-lg font-semibold transition mr-1">Préparer</button>`;
                        break;
                    case 'preparing':
                        statusBadge = `<span class="bg-amber-600/10 text-amber-400 border border-amber-500/20 px-2 py-0.5 rounded-full">préparation</span>`;
                        actions = `<button onclick="updateOrderStatus(${o.id}, 'shipping')" class="px-2.5 py-1 bg-orange-600 hover:bg-orange-500 text-white rounded-lg font-semibold transition mr-1">Expédier</button>`;
                        break;
                    case 'shipping':
                        statusBadge = `<span class="bg-orange-600/10 text-orange-400 border border-orange-500/20 px-2 py-0.5 rounded-full">en cours</span>`;
                        actions = `<button onclick="updateOrderStatus(${o.id}, 'delivered')" class="px-2.5 py-1 bg-teal-600 hover:bg-teal-500 text-white rounded-lg font-semibold transition mr-1">Livrer</button>`;
                        break;
                    case 'delivered':
                        statusBadge = `<span class="bg-teal-600/10 text-teal-400 border border-teal-500/20 px-2 py-0.5 rounded-full">livré</span>`;
                        actions = `<span class="text-xs text-slate-500 italic">En attente client</span>`;
                        break;
                    case 'confirmed':
                        statusBadge = `<span class="bg-emerald-600/15 text-emerald-400 border border-emerald-500/25 px-2 py-0.5 rounded-full">confirmé</span>`;
                        actions = `<span class="text-xs text-emerald-500 font-semibold">Validé</span>`;
                        break;
                }

                return `
                    <tr class="hover:bg-slate-850/50 transition">
                        <td class="py-3 font-bold text-slate-100">#${o.id}</td>
                        <td class="py-3">${o.customerName} <span class="text-[10px] text-slate-500">(ID: ${o.customerId})</span></td>
                        <td class="py-3 text-slate-200 font-semibold">${numberWithSpaces(o.totalAmount)} FC</td>
                        <td class="py-3">${o.paymentMethod}</td>
                        <td class="py-3">${statusBadge}</td>
                        <td class="py-3 text-right">${actions}</td>
                    </tr>
                `;
            }).join('');
        }

        // Admin Order Status Update
        async function updateOrderStatus(orderId, status) {
            try {
                const res = await fetch(`/api/admin/orders/${orderId}/status`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + jwtToken
                    },
                    body: JSON.stringify({ status })
                });

                if (res.ok) {
                    showToast("Statut mis à jour", `La commande #${orderId} est passée à "${status}"`);
                    loadAdminPortalData();
                } else {
                    const data = await res.json();
                    showToast("Erreur", data.message || "Erreur de mise à jour", true);
                }
            } catch (err) {
                console.error(err);
                showToast("Erreur", "Erreur réseau", true);
            }
        }

        // Record offline payment
        async function submitAdminPayment() {
            const beneficiaryId = document.getElementById('pay-beneficiary-id').value;
            const amount = document.getElementById('pay-amount').value;
            const paymentMethod = document.getElementById('pay-method').value;
            const transactionReference = document.getElementById('pay-reference').value;

            if (!beneficiaryId || !amount) {
                showToast("Erreur", "Bénéficiaire et montant requis", true);
                return;
            }

            try {
                const res = await fetch('/api/admin/payments', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + jwtToken
                    },
                    body: JSON.stringify({ beneficiaryId: parseInt(beneficiaryId), amount, paymentMethod, transactionReference })
                });

                const data = await res.json();
                if (res.status === 201) {
                    showToast("Paiement enregistré", `Le versement de ${numberWithSpaces(amount)} FC a été enregistré`);
                    // Clear inputs
                    document.getElementById('pay-beneficiary-id').value = '';
                    document.getElementById('pay-amount').value = '';
                    document.getElementById('pay-reference').value = '';
                    loadAdminPortalData();
                } else {
                    showToast("Erreur", data.message || "Erreur d'enregistrement", true);
                }
            } catch (err) {
                console.error(err);
                showToast("Erreur", "Erreur de communication", true);
            }
        }

