                            <div>
                                <span class="font-semibold block text-slate-200">${p.name}</span>
                                <span class="text-[10px] text-slate-500 block truncate max-w-xs">${p.description || "Pas de description"}</span>
                            </div>
                        </div>
                    </td>
                    <td class="py-3 text-slate-200 font-semibold">${numberWithSpaces(p.price)} FC</td>
                    <td class="py-3 text-slate-400">${p.category || "Aucune"}</td>
                    <td class="py-3 text-slate-300 font-semibold">${p.stock}</td>
                    <td class="py-3">
                        ${p.isAvailable 
                            ? '<span class="bg-emerald-600/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded-full text-[10px]">Disponible</span>' 
                            : '<span class="bg-red-600/10 text-red-400 border border-red-500/20 px-2 py-0.5 rounded-full text-[10px]">Indisponible</span>'
                        }
                    </td>
                    <td class="py-3 text-right space-x-2">
                        <button onclick="openProductModal(${p.id})" class="px-2.5 py-1 bg-slate-800 hover:bg-slate-700 text-slate-250 rounded-lg text-[11px] font-semibold transition inline-flex items-center space-x-1">
                            <i data-lucide="edit-3" class="w-3.5 h-3.5"></i><span>Modifier</span>
                        </button>
                        <button onclick="deleteProduct(${p.id})" class="px-2.5 py-1 bg-red-955/40 hover:bg-red-900/40 text-red-400 rounded-lg text-[11px] font-semibold transition inline-flex items-center space-x-1">
                            <i data-lucide="trash" class="w-3.5 h-3.5"></i><span>Supprimer</span>
                        </button>
