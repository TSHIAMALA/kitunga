    <!-- Scripts / logic -->
    <script>
        // State variables
        let products = [];
        let cart = [];
        let jwtToken = localStorage.getItem('jwt_token') || '';
        let currentUser = JSON.parse(localStorage.getItem('current_user') || 'null');
        let currentAuthTab = 'login';
        let currentCategory = '';
        let simData = {
            codeA: '', emailA: 'referrer_a_sim@example.com',
            codeB: '', emailB: 'referrer_b_sim@example.com',
            codeC: '', emailC: 'buyer_c_sim@example.com',
            orderId: '',
            rizProduct: null
        };

        // Admin State variables
        let currentAdminTab = 'dashboard';
        let adminCategories = [];
        let adminProducts = [];
        let adminUsers = [];
        let adminStockMovements = [];
        let editingProductId = null;
        let editingCategoryId = null;
        let editingUserId = null;

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            loadProducts();
            if (jwtToken && currentUser) {
                updateUIForAuthenticatedUser();
            }
        });

        // Toast Helper
        function showToast(title, message, isError = false) {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toast-icon');
            const titleEl = document.getElementById('toast-title');
            const msgEl = document.getElementById('toast-message');

            titleEl.textContent = title;
            msgEl.textContent = message;

            if (isError) {
                icon.className = "p-2 rounded-lg bg-red-600 text-white";
                icon.innerHTML = '<i data-lucide="alert-circle" class="w-5 h-5"></i>';
            } else {
                icon.className = "p-2 rounded-lg bg-primary-500 text-white";
                icon.innerHTML = '<i data-lucide="check" class="w-5 h-5"></i>';
            }
            lucide.createIcons();

            toast.classList.remove('hidden');
            setTimeout(() => toast.classList.remove('translate-x-80'), 10);

            setTimeout(() => {
                toast.classList.add('translate-x-80');
                setTimeout(() => toast.classList.add('hidden'), 300);
            }, 4000);
        }

        // Fetch Products
        async function loadProducts() {
            try {
                let url = '/api/products';
                if (currentCategory) {
                    url += `?category=${currentCategory}`;
                }
                const res = await fetch(url);
                products = await res.json();
                renderProducts();
            } catch (err) {
                console.error(err);
                showToast("Erreur", "Impossible de charger le catalogue", true);
            }
        }

        // Render Products Grid
        function renderProducts() {
            const grid = document.getElementById('products-grid');
            if (products.length === 0) {
                grid.innerHTML = `<div class="col-span-full text-center py-12 text-slate-500 text-xs">Aucun produit disponible.</div>`;
                return;
            }

            grid.innerHTML = products.map(p => {
                const imgUrl = p.imageUrl ? (p.imageUrl.startsWith('http') ? p.imageUrl : '/' + p.imageUrl.replace(/^\//, '')) : '';
                return `
                <div class="glass rounded-3xl p-5 flex flex-col justify-between shadow-lg relative group border border-slate-800/80 hover:border-primary-500/40 transition-all duration-300 hover:shadow-primary-950/20">
                    <div>
                        <!-- Badge stock -->
                        <div class="absolute top-4 right-4 flex space-x-1.5 opacity-90 z-10">
                            <span class="bg-primary-500/10 text-primary-400 text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">${p.category}</span>
                            <span class="bg-slate-800/80 text-slate-400 text-[9px] font-semibold px-2 py-0.5 rounded-full">Stock: ${p.stock}</span>
                        </div>
                        
                        <!-- Simple image container with gradient -->
                        <div class="h-40 rounded-2xl bg-gradient-to-tr from-slate-800/80 to-slate-900 flex items-center justify-center mb-4 relative overflow-hidden">
                            ${imgUrl ? `
                                <img src="${imgUrl}" alt="${p.name}" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');">
                                <div class="hidden w-full h-full flex items-center justify-center relative">
                                    <i data-lucide="salad" class="w-12 h-12 text-primary-500/20"></i>
                                    <div class="absolute inset-0 bg-gradient-to-t from-slate-955/80 to-transparent pointer-events-none"></div>
                                </div>
                            ` : `
                                <i data-lucide="salad" class="w-12 h-12 text-primary-500/20 group-hover:text-primary-400/30 group-hover:scale-110 transition duration-300"></i>
                                <div class="absolute inset-0 bg-gradient-to-t from-slate-955/80 to-transparent pointer-events-none"></div>
                            `}
                        </div>
                        
                        <h3 class="text-sm font-bold text-slate-100 group-hover:text-primary-400 transition">${p.name}</h3>
                        <p class="text-[11px] text-slate-400 mt-1.5 leading-relaxed">${p.description || "Aucune description."}</p>
                    </div>

                    <div class="flex items-center justify-between mt-5 pt-4 border-t border-slate-850">
                        <span class="font-extrabold text-accent-gold text-sm">${numberWithSpaces(p.price)} <span class="text-[10px] font-medium text-slate-400">FC</span></span>
                        <button onclick="addToCart(${p.id})" class="px-3.5 py-1.5 bg-primary-600 hover:bg-primary-500 text-white text-xs font-semibold rounded-xl transition shadow-md shadow-primary-950/20 flex items-center space-x-1">
                            <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                            <span>Ajouter</span>
                        </button>
                    </div>
                </div>
            `}).join('');
            lucide.createIcons();

            // Set simulator riz
            simData.rizProduct = products.find(p => p.name === 'Riz de Bumba');
        }

        // Filter Catalog
        function filterCatalog(cat) {
            currentCategory = cat;
            document.getElementById('cat-all').className = cat === '' ? 'px-3 py-1.5 bg-primary-600 text-white text-xs font-semibold rounded-lg transition' : 'px-3 py-1.5 text-slate-400 hover:text-white text-xs font-semibold rounded-lg transition';
            document.getElementById('cat-poissons').className = cat === 'Poissons' ? 'px-3 py-1.5 bg-primary-600 text-white text-xs font-semibold rounded-lg transition' : 'px-3 py-1.5 text-slate-400 hover:text-white text-xs font-semibold rounded-lg transition';
            document.getElementById('cat-feculents').className = cat === 'Féculents' ? 'px-3 py-1.5 bg-primary-600 text-white text-xs font-semibold rounded-lg transition' : 'px-3 py-1.5 text-slate-400 hover:text-white text-xs font-semibold rounded-lg transition';
            loadProducts();
        }

        // Helper spaces
        function numberWithSpaces(x) {
            return parseFloat(x).toLocaleString('fr-FR');
        }

        // Cart Drawer actions
        function toggleCartDrawer() {
            const drawer = document.getElementById('cart-drawer');
            drawer.classList.toggle('hidden');
            setTimeout(() => {
                drawer.classList.toggle('translate-x-full');
            }, 10);
            renderCart();
        }

        // Add to Cart
        function addToCart(productId) {
            const product = products.find(p => p.id === productId);
            if (!product) return;

            const existing = cart.find(item => item.product.id === productId);
            if (existing) {
                if (existing.quantity >= product.stock) {
                    showToast("Limite de stock", "Vous ne pouvez pas ajouter plus que la quantité disponible", true);
                    return;
                }
                existing.quantity++;
            } else {
                cart.push({ product, quantity: 1 });
            }
            updateCartBadge();
            showToast("Panier", `"${product.name}" ajouté au panier`);
        }

        // Remove/adjust cart
        function changeCartQuantity(productId, delta) {
            const item = cart.find(item => item.product.id === productId);
            if (!item) return;

            item.quantity += delta;
            if (item.quantity <= 0) {
                cart = cart.filter(i => i.product.id !== productId);
            }
            updateCartBadge();
            renderCart();
        }

        // Update badge
        function updateCartBadge() {
            const badge = document.getElementById('cart-badge');
            const badgeMobile = document.getElementById('cart-badge-mobile');
            const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
            
            if (totalItems > 0) {
                if (badge) {
                    badge.textContent = totalItems;
                    badge.classList.remove('hidden');
                }
                if (badgeMobile) {
                    badgeMobile.textContent = totalItems;
                    badgeMobile.classList.remove('hidden');
                }
            } else {
                if (badge) badge.classList.add('hidden');
                if (badgeMobile) badgeMobile.classList.add('hidden');
            }
        }

        // Render Cart
        function renderCart() {
            const container = document.getElementById('cart-items-container');
            const checkoutForm = document.getElementById('checkout-form-wrapper');

            if (cart.length === 0) {
                container.innerHTML = `<p class="text-xs text-slate-500 text-center py-12">Votre panier est vide.</p>`;
                checkoutForm.classList.add('hidden');
                updateCartTotals(0);
                return;
            }

            checkoutForm.classList.remove('hidden');

            container.innerHTML = cart.map(item => `
                <div class="flex items-center justify-between bg-slate-900/60 border border-slate-850 p-3 rounded-2xl">
                    <div class="flex-1 pr-3">
                        <h4 class="text-xs font-bold text-slate-200">${item.product.name}</h4>
                        <p class="text-[10px] text-accent-gold font-bold mt-1">${numberWithSpaces(item.product.price)} FC</p>
                    </div>
                    <div class="flex items-center space-x-2">
                        <button onclick="changeCartQuantity(${item.product.id}, -1)" class="w-6 h-6 flex items-center justify-center rounded-lg bg-slate-800 text-slate-300 hover:text-white border border-slate-700/50">-</button>
                        <span class="text-xs font-bold text-slate-100">${item.quantity}</span>
                        <button onclick="changeCartQuantity(${item.product.id}, 1)" class="w-6 h-6 flex items-center justify-center rounded-lg bg-slate-800 text-slate-300 hover:text-white border border-slate-700/50">+</button>
                    </div>
                </div>
            `).join('');
            
            const subtotal = cart.reduce((sum, item) => sum + (parseFloat(item.product.price) * item.quantity), 0);
            updateCartTotals(subtotal);
        }

        function updateCartTotals(subtotal) {
            const deliveryFee = subtotal > 0 ? 5000 : 0;
            const total = subtotal + deliveryFee;

            document.getElementById('cart-subtotal').textContent = numberWithSpaces(subtotal) + " FC";
            document.getElementById('cart-delivery-fee').textContent = numberWithSpaces(deliveryFee) + " FC";
            document.getElementById('cart-total').textContent = numberWithSpaces(total) + " FC";
        }

        // Proceed to Checkout
        async function proceedToCheckout() {
            if (!jwtToken) {
                showToast("Connexion requise", "Veuillez vous connecter pour valider la commande", true);
                openAuthModal();
                return;
            }

            const address = document.getElementById('checkout-address').value;
            const paymentMethod = document.getElementById('checkout-payment-method').value;

            if (!address) {
                showToast("Erreur", "L'adresse de livraison est requise", true);
                return;
            }

            const items = cart.map(i => ({
                productId: i.product.id,
                quantity: i.quantity
            }));

            try {
                const res = await fetch('/api/orders', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + jwtToken
                    },
                    body: json_encode_raw({ deliveryAddress: address, paymentMethod, items })
                });

                const data = await res.json();
                if (data.status === 'success') {
                    showToast("Commande validée", "Votre commande a été enregistrée avec succès");
                    cart = [];
                    updateCartBadge();
                    toggleCartDrawer();
                    loadProducts();
                    loadClientDashboard();
                } else {
                    showToast("Erreur", data.message || "Impossible de valider la commande", true);
                }
            } catch (err) {
                console.error(err);
                showToast("Erreur", "Erreur réseau lors de la commande", true);
            }
        }

        // Raw json helper
        function json_encode_raw(obj) {
            return JSON.stringify(obj);
        }

        // Modal Auth Actions
        function openAuthModal() {
            redirectToLogin();
        }

        function closeAuthModal() {
            document.getElementById('auth-modal').classList.add('hidden');
        }

        function switchAuthTab(tab) {
            currentAuthTab = tab;
            const tabLogin = document.getElementById('auth-tab-login');
            const tabRegister = document.getElementById('auth-tab-register');
            const formLogin = document.getElementById('form-login');
            const formRegister = document.getElementById('form-register');

            if (tab === 'login') {
                tabLogin.className = "flex-1 py-1.5 text-center text-sm font-bold text-primary-400 border-b-2 border-primary-500";
                tabRegister.className = "flex-1 py-1.5 text-center text-sm font-bold text-slate-400 hover:text-slate-200";
                formLogin.classList.remove('hidden');
                formRegister.classList.add('hidden');
            } else {
                tabRegister.className = "flex-1 py-1.5 text-center text-sm font-bold text-primary-400 border-b-2 border-primary-500";
                tabLogin.className = "flex-1 py-1.5 text-center text-sm font-bold text-slate-400 hover:text-slate-200";
                formRegister.classList.remove('hidden');
                formLogin.classList.add('hidden');
            }
        }

        // Authenticate submitting
        async function handleLoginSubmit(e) {
            e.preventDefault();
            const email = document.getElementById('login-email').value;
            const password = document.getElementById('login-password').value;

            try {
                const res = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });

                if (res.status === 200) {
                    const data = await res.json();
                    jwtToken = data.token;
                    localStorage.setItem('jwt_token', jwtToken);
                    
                    // Decode token claims simple
                    const payload = JSON.parse(atob(jwtToken.split('.')[1]));
                    currentUser = {
                        email: payload.username,
                        roles: payload.roles || []
                    };
                    localStorage.setItem('current_user', JSON.stringify(currentUser));
                    
                    showToast("Connexion réussie", "Vous êtes maintenant connecté");
                    closeAuthModal();
                    updateUIForAuthenticatedUser();
                } else {
                    showToast("Connexion échouée", "Identifiants invalides", true);
                }
            } catch (err) {
                console.error(err);
                showToast("Erreur", "Erreur de communication", true);
            }
        }

        async function handleRegisterSubmit(e) {
            e.preventDefault();
            const fullName = document.getElementById('reg-name').value;
            const email = document.getElementById('reg-email').value;
            const phone = document.getElementById('reg-phone').value;
            const password = document.getElementById('reg-password').value;
            const referrerCode = document.getElementById('reg-referrer').value;

            try {
                const res = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName, email, phone, password, referrerCode })
                });

                const data = await res.json();
                if (res.status === 201) {
                    showToast("Inscription validée", `Code généré: ${data.user.referralCode}`);
                    switchAuthTab('login');
                    document.getElementById('login-email').value = email;
                    document.getElementById('login-password').value = password;
                } else {
                    let errMsg = "Erreur d'inscription";
                    if (data.errors) {
                        errMsg = Object.values(data.errors).join(', ');
                    }
                    showToast("Erreur d'inscription", errMsg, true);
                }
            } catch (err) {
                console.error(err);
                showToast("Erreur", "Erreur réseau", true);
            }
        }

        // Sidebar navigation & Layout helpers
        function toggleSidebarSection(sectionId) {
            const section = document.getElementById(sectionId);
            const chevron = document.getElementById(sectionId + '-chevron');
            if (section && chevron) {
                section.classList.toggle('hidden');
                chevron.classList.toggle('rotated');
            }
        }

        function toggleMobileSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            if (sidebar && overlay) {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('show');
            }
        }

        function showSection(sectionType, activeMenuId) {
            const clientPortal = document.getElementById('client-portal-view');
            const adminPortal = document.getElementById('admin-portal-view');

            // Active menu link styling
            document.querySelectorAll('.sidebar-item').forEach(item => {
                item.classList.remove('active');
                const dot = item.querySelector('.active-dot');
                if (dot) dot.remove();
            });

            const currentActiveId = activeMenuId || (sectionType === 'admin-portal' ? 'menu-admin-dashboard' : 'menu-catalog');
            const activeItem = document.getElementById(currentActiveId);
            if (activeItem) {
                activeItem.classList.add('active');
                if (!activeItem.querySelector('.active-dot')) {
                    const dot = document.createElement('span');
                    dot.className = 'active-dot';
                    activeItem.appendChild(dot);
                }
            }

            if (sectionType === 'admin-portal') {
                clientPortal.classList.add('hidden');
                adminPortal.classList.remove('hidden');
            } else {
                adminPortal.classList.add('hidden');
                clientPortal.classList.remove('hidden');
            }

            // close mobile menu
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            if (sidebar) sidebar.classList.remove('open');
            if (overlay) overlay.classList.remove('show');
        }

        function scrollToElement(id) {
            showSection('client-portal');
            const el = document.getElementById(id);
            if (el) {
                el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                // highlight briefly
                el.classList.add('ring-2', 'ring-primary-500');
                setTimeout(() => el.classList.remove('ring-2', 'ring-primary-500'), 2000);
            }
            // Close mobile menu
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            sidebar.classList.remove('open');
            overlay.classList.remove('show');
        }

        function redirectToLogin() {
            window.location.href = '/login';
        }

        function updateUIForAuthenticatedUser() {
            // Sidebar auth section
            const sidebarAuth = document.getElementById('sidebar-auth-section');
            if (sidebarAuth) {
                sidebarAuth.innerHTML = `
                    <div class="flex flex-col gap-2 bg-white/5 p-3 rounded-2xl border border-white/5">
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-full bg-primary-600/30 flex items-center justify-center text-xs font-bold text-primary-400">
                                ${currentUser.email.substring(0, 2).toUpperCase()}
                            </div>
                            <div class="overflow-hidden">
                                <p class="text-xs text-slate-200 font-semibold truncate">${currentUser.email}</p>
                                <p class="text-[9px] text-slate-500 uppercase tracking-wider">Connecté</p>
                            </div>
                        </div>
                        <button onclick="handleLogout()" class="w-full mt-1.5 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-semibold rounded-xl transition flex items-center justify-center gap-1.5 border border-red-500/10">
                            <i data-lucide="log-out" class="w-3.5 h-3.5"></i>
                            <span>Déconnexion</span>
                        </button>
                    </div>
                `;
            }
