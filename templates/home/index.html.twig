        // Run Step 1: Create A, B, C network
        async function runStep1() {
            writeToConsole("Initialisation de l'étape 1 : Inscriptions en cascade...");
            const suffix = Math.floor(Math.random() * 10000);
            simData.emailA = `ref_a_${suffix}@kitunga.com`;
            simData.emailB = `ref_b_${suffix}@kitunga.com`;
            simData.emailC = `buyer_c_${suffix}@kitunga.com`;

            try {
                // 1. Register A
                writeToConsole("Création du Parrain A...");
                let res = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName: 'Parrain A', email: simData.emailA, phone: `+24381${suffix}01`, password: 'password123' })
                });
                let data = await res.json();
                if (res.status !== 201) throw new Error("Échec création A: " + (data.message || JSON.stringify(data.errors)));
                simData.codeA = data.user.referralCode;
                writeToConsole(`Parrain A créé. Code: ${simData.codeA}`, true);

                // 2. Register B parrainé par A
                writeToConsole("Création du Parrain B (parrainé par A)...");
                res = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName: 'Parrain B', email: simData.emailB, phone: `+24381${suffix}02`, password: 'password123', referrerCode: simData.codeA })
                });
                data = await res.json();
                if (res.status !== 201) throw new Error("Échec création B: " + (data.message || JSON.stringify(data.errors)));
                simData.codeB = data.user.referralCode;
                writeToConsole(`Parrain B créé. Code: ${simData.codeB}`, true);

                // 3. Register C parrainé par B
                writeToConsole("Création du Client C (parrainé par B)...");
                res = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName: 'Client C', email: simData.emailC, phone: `+24381${suffix}03`, password: 'password123', referrerCode: simData.codeB })
                });
                data = await res.json();
                if (res.status !== 201) throw new Error("Échec création C: " + (data.message || JSON.stringify(data.errors)));
                writeToConsole(`Client C créé avec succès parrainé par B !`, true);

                // Enable Step 2
                document.getElementById('sim-step-1').classList.add('opacity-50');
                document.getElementById('sim-step-2').classList.remove('opacity-50');
                document.getElementById('btn-step-2').disabled = false;
                document.getElementById('btn-step-2').className = "mt-4 w-full py-2 bg-primary-600 hover:bg-primary-500 text-white text-xs font-semibold rounded-xl transition flex items-center justify-center space-x-1.5 shadow";

                writeToConsole("Étape 1 terminée avec succès ! Passez à l'Étape 2.", true);
            } catch (err) {
                writeToConsole("[Erreur] " + err.message);
                showToast("Erreur", err.message, true);
            }
        }

        // Run Step 2: C Orders 100k
        async function runStep2() {
            writeToConsole("Initialisation de l'étape 2 : Connexion de C et commande...");
            try {
                // 1. Login C
                writeToConsole("Authentification du Client C...");
                let res = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: simData.emailC, password: 'password123' })
                });
                if (!res.ok) throw new Error("Échec connexion C");
                const loginData = await res.json();
                const tokenC = loginData.token;
                writeToConsole("Client C connecté avec succès.", true);

                // Find Riz Product
                if (!simData.rizProduct) {
                    const productsRes = await fetch('/api/products');
                    const productsList = await productsRes.json();
                    simData.rizProduct = productsList.find(p => p.name === 'Riz de Bumba');
                }

                if (!simData.rizProduct) throw new Error("Produit 'Riz de Bumba' introuvable");

                // 2. Place Order
                writeToConsole("Envoi de la commande de 4 sacs de Riz de Bumba (100 000 FC)...");
                res = await fetch('/api/orders', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + tokenC
                    },
                    body: JSON.stringify({
                        deliveryAddress: 'Avenue de la Justice, Gombe, Kinshasa',
                        paymentMethod: 'M-Pesa',
                        items: [{ productId: simData.rizProduct.id, quantity: 4 }]
                    })
                });
                const data = await res.json();
                if (res.status !== 201) throw new Error("Échec commande: " + data.message);
                simData.orderId = data.order.id;
                writeToConsole(`Commande #${simData.orderId} enregistrée. Sous-total: ${data.order.subtotal} FC. Statut: reçu`, true);

                // Enable Step 3
                document.getElementById('sim-step-2').classList.add('opacity-50');
                document.getElementById('sim-step-3').classList.remove('opacity-50');
                document.getElementById('btn-step-3').disabled = false;
                document.getElementById('btn-step-3').className = "mt-4 w-full py-2 bg-primary-600 hover:bg-primary-500 text-white text-xs font-semibold rounded-xl transition flex items-center justify-center space-x-1.5 shadow";

                writeToConsole("Étape 2 terminée avec succès ! Passez à l'Étape 3.", true);
            } catch (err) {
                writeToConsole("[Erreur] " + err.message);
                showToast("Erreur", err.message, true);
            }
        }

        // Run Step 3: Admin delivers
        async function runStep3() {
            writeToConsole("Initialisation de l'étape 3 : Livraison de la commande...");
            try {
                // Login Admin
                writeToConsole("Connexion de l'Administrateur...");
                let res = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: 'admin@kitunga.com', password: 'adminpassword' })
                });
                if (!res.ok) throw new Error("Échec connexion Admin");
                const adminToken = (await res.json()).token;

                // Update Status to 'delivered'
                writeToConsole(`Mise à jour du statut de la commande #${simData.orderId} à "delivered"...`);
                res = await fetch(`/api/admin/orders/${simData.orderId}/status`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + adminToken
                    },
                    body: JSON.stringify({ status: 'delivered' })
                });
                const data = await res.json();
                if (!res.ok) throw new Error("Échec livraison: " + data.message);
                writeToConsole("Commande marquée comme livrée par l'administrateur.", true);

                // Enable Step 4
                document.getElementById('sim-step-3').classList.add('opacity-50');
                document.getElementById('sim-step-4').classList.remove('opacity-50');
                document.getElementById('btn-step-4').disabled = false;
                document.getElementById('btn-step-4').className = "mt-4 w-full py-2 bg-primary-600 hover:bg-primary-500 text-white text-xs font-semibold rounded-xl transition flex items-center justify-center space-x-1.5 shadow";

                writeToConsole("Étape 3 terminée ! Passez à l'Étape 4 pour confirmer la réception en tant que C.", true);
            } catch (err) {
                writeToConsole("[Erreur] " + err.message);
                showToast("Erreur", err.message, true);
            }
        }

        // Run Step 4: C Confirms
        async function runStep4() {
            writeToConsole("Initialisation de l'étape 4 : Confirmation du Client C...");
            try {
                // Login C again
                writeToConsole("Authentification du Client C...");
                let res = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: simData.emailC, password: 'password123' })
                });
                if (!res.ok) throw new Error("Échec connexion C");
                const tokenC = (await res.json()).token;

                // Confirm reception
                writeToConsole(`Confirmation de la livraison pour la commande #${simData.orderId} par Client C...`);
                res = await fetch(`/api/orders/${simData.orderId}/confirm`, {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + tokenC }
                });
                const data = await res.json();
                if (!res.ok) throw new Error("Échec confirmation: " + data.message);
                writeToConsole("Réception confirmée par C ! Commissions générées.", true);

                // Enable Step 5
                document.getElementById('sim-step-4').classList.add('opacity-50');
                document.getElementById('sim-step-5').classList.remove('opacity-50');
                document.getElementById('btn-step-5').disabled = false;
                document.getElementById('btn-step-5').className = "mt-4 w-full py-2 bg-primary-600 hover:bg-primary-500 text-white text-xs font-semibold rounded-xl transition flex items-center justify-center space-x-1.5 shadow";

                writeToConsole("Étape 4 terminée ! Passez à l'Étape 5 pour vérifier les gains.", true);
            } catch (err) {
                writeToConsole("[Erreur] " + err.message);
                showToast("Erreur", err.message, true);
            }
        }

        // Run Step 5: Check Balances
        async function runStep5() {
            writeToConsole("Initialisation de l'étape 5 : Vérification des soldes...");
            try {
                // 1. Connect B (L1) and check availableBalance
                writeToConsole("Vérification du portefeuille de B (Parrain direct)...");
                let res = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: simData.emailB, password: 'password123' })
                });
                let tokenB = (await res.json()).token;
                
                res = await fetch('/api/wallet', {
                    headers: { 'Authorization': 'Bearer ' + tokenB }
                });
                let walletB = await res.json();
                writeToConsole(`Portefeuille B - Solde: ${numberWithSpaces(walletB.availableBalance)} FC (Attendu: 5 000 FC pour 5% de 100k FC)`, true);

                // 2. Connect A (L2) and check availableBalance
                writeToConsole("Vérification du portefeuille de A (Grand-parrain)...");
                res = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: simData.emailA, password: 'password123' })
                });
                let tokenA = (await res.json()).token;
                
                res = await fetch('/api/wallet', {
                    headers: { 'Authorization': 'Bearer ' + tokenA }
                });
                let walletA = await res.json();
                writeToConsole(`Portefeuille A - Solde: ${numberWithSpaces(walletA.availableBalance)} FC (Attendu: 2 000 FC pour 2% de 100k FC)`, true);

                writeToConsole("=== SIMULATION TERMINÉE AVEC SUCCÈS ===", true);
                showToast("Simulation réussie", "Tous les soldes ont été vérifiés avec succès !");

                // Disable Step 5
                document.getElementById('sim-step-5').classList.add('opacity-50');
                document.getElementById('btn-step-5').disabled = true;
                document.getElementById('btn-step-5').className = "mt-4 w-full py-2 bg-slate-800 text-slate-500 text-xs font-semibold rounded-xl transition flex items-center justify-center space-x-1.5";

                // Auto reload if user is connected
                if (jwtToken) {
                    loadClientDashboard();
                }
            } catch (err) {
                writeToConsole("[Erreur] " + err.message);
                showToast("Erreur", err.message, true);
            }
        }
    </script>
</body>
</html>
