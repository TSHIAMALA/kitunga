                    </div>
                    <div class="flex-grow">
                        <div class="flex justify-between items-center">
                            <h4 class="text-[11px] font-bold text-slate-200">${n.title}</h4>
                            <span class="text-[9px] text-slate-500">${formatDateIso(n.createdAt)}</span>
