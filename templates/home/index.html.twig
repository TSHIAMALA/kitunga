                if (u.status === 'blocked') {
                    statusColor = "bg-red-600/10 text-red-400 border border-red-500/20";
                }

                const roles = u.roles || ['ROLE_USER'];
                const roleBadges = roles.map(r => {
                    if (r === 'ROLE_ADMIN') return '<span class="bg-amber-600/10 text-amber-400 border border-amber-500/20 px-2 py-0.5 rounded-full text-[9px]">Admin</span>';
                    return '<span class="bg-blue-600/10 text-blue-400 border border-blue-500/20 px-2 py-0.5 rounded-full text-[9px]">Client</span>';
                }).join(' ');

                const isBlocked = u.status === 'blocked';
                const toggleStatusAction = isBlocked ? 'active' : 'blocked';
                const toggleStatusText = isBlocked ? 'Débloquer' : 'Bloquer';
                const toggleStatusBtnColor = isBlocked ? 'bg-emerald-955/40 hover:bg-emerald-900/40 text-emerald-400' : 'bg-orange-955/40 hover:bg-orange-900/40 text-orange-400';
                const toggleStatusIcon = isBlocked ? 'unlock font-bold' : 'lock font-bold';

                return `
                    <tr class="hover:bg-slate-850/50 transition border-b border-slate-800/40">
                        <td class="py-3 font-bold text-slate-100">#${u.id}</td>
