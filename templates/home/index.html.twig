                return;
            }

            tbody.innerHTML = items.map(p => {
                const imgUrl = p.imageUrl ? (p.imageUrl.startsWith('http') ? p.imageUrl : '/' + p.imageUrl.replace(/^\//, '')) : '';
                return `
                <tr class="hover:bg-slate-850/50 transition border-b border-slate-800/40">
                    <td class="py-3 font-bold text-slate-100">#${p.id}</td>
                    <td class="py-3">
                        <div class="flex items-center space-x-3">
                            <div class="w-8 h-8 rounded bg-slate-800 flex items-center justify-center text-slate-400 overflow-hidden">
                                ${imgUrl ? `
                                    <img src="${imgUrl}" alt="${p.name}" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');">
                                    <div class="hidden">
                                        <i data-lucide="salad" class="w-4 h-4"></i>
                                    </div>
                                ` : `
                                    <i data-lucide="salad" class="w-4 h-4"></i>
                                `}
