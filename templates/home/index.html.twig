        function handleLogout() {
            localStorage.removeItem('jwt_token');
            localStorage.removeItem('current_user');
            jwtToken = '';
            currentUser = null;

            // Reset sidebar auth section
            const sidebarAuth = document.getElementById('sidebar-auth-section');
            if (sidebarAuth) {
                sidebarAuth.innerHTML = `
                    <button onclick="redirectToLogin()" class="w-full py-2 bg-primary-600 hover:bg-primary-500 text-white text-xs font-semibold rounded-xl transition flex items-center justify-center gap-2">
                        <i data-lucide="log-in" class="w-4 h-4"></i>
                        <span>Connexion</span>
                    </button>
                `;
            }
            lucide.createIcons();

            // Hide member & admin sections in sidebar
            const memberSection = document.getElementById('menu-section-member');
            if (memberSection) memberSection.classList.add('hidden');
            const adminSection = document.getElementById('menu-section-admin');
            if (adminSection) adminSection.classList.add('hidden');

            // Hide cards
            document.getElementById('dashboard-wallet-card').classList.add('hidden');
            document.getElementById('dashboard-orders-card').classList.add('hidden');
            document.getElementById('dashboard-notifications-card').classList.add('hidden');
            
            // Switch back view
            document.getElementById('admin-portal-view').classList.add('hidden');
            document.getElementById('client-portal-view').classList.remove('hidden');

            showToast("Déconnexion", "Vous êtes déconnecté");
        }

        // Load Client Dashboard Data
        async function loadClientDashboard() {
            if (!jwtToken) return;

            try {
                // 1. Wallet & Referrals stats
                const walletRes = await fetch('/api/wallet', {
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                const wallet = await walletRes.json();

                document.getElementById('wallet-client-name').textContent = currentUser.email;
                document.getElementById('wallet-balance').textContent = numberWithSpaces(wallet.availableBalance);
                document.getElementById('wallet-total-generated').textContent = numberWithSpaces(wallet.totalGenerated) + " FC";
                document.getElementById('wallet-total-paid').textContent = numberWithSpaces(wallet.totalPaid) + " FC";
                document.getElementById('wallet-referral-code').textContent = wallet.referrals.code;
                document.getElementById('wallet-direct-count').textContent = wallet.referrals.directCount;
                document.getElementById('wallet-indirect-count').textContent = wallet.referrals.indirectCount;

                // 2. Orders list
                const ordersRes = await fetch('/api/orders', {
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                const orders = await ordersRes.json();
                renderClientOrders(orders);

                // 3. Notifications list
                const notifRes = await fetch('/api/notifications', {
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                const notifications = await notifRes.json();
                renderClientNotifications(notifications);

            } catch (err) {
                console.error(err);
            }
        }

        // Render customer orders
        function renderClientOrders(orders) {
            const list = document.getElementById('customer-orders-list');
            if (orders.length === 0) {
                list.innerHTML = `<p class="text-xs text-slate-500 text-center py-4">Aucune commande.</p>`;
                return;
            }

            list.innerHTML = orders.map(o => {
                let statusColor = "bg-slate-800 text-slate-400";
                let actionBtn = "";

                switch (o.status) {
                    case 'received': statusColor = "bg-blue-600/10 text-blue-400 border border-blue-500/20"; break;
                    case 'preparing': statusColor = "bg-amber-600/10 text-amber-400 border border-amber-500/20"; break;
                    case 'shipping': statusColor = "bg-orange-600/10 text-orange-400 border border-orange-500/20"; break;
                    case 'delivered': 
                        statusColor = "bg-teal-600/10 text-teal-400 border border-teal-500/20 animate-pulse";
                        actionBtn = `<button onclick="confirmOrderDelivery(${o.id})" class="mt-2.5 w-full py-1.5 bg-primary-600 hover:bg-primary-500 text-white text-[11px] font-bold rounded-lg transition shadow">Confirmer la réception</button>`;
                        break;
                    case 'confirmed': statusColor = "bg-emerald-600/15 text-emerald-400 border border-emerald-500/25"; break;
                }

                return `
                    <div class="bg-slate-900/60 border border-slate-850 p-3.5 rounded-2xl">
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-bold text-slate-200">Cmd #${o.id}</span>
                            <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full ${statusColor}">${o.status}</span>
                        </div>
                        <div class="flex items-center justify-between text-[11px] text-slate-400 mt-2">
                            <span>Total: <b class="text-slate-200">${numberWithSpaces(o.totalAmount)} FC</b></span>
                            <span>${formatDateIso(o.createdAt)}</span>
                        </div>
                        ${actionBtn}
                    </div>
                `;
            }).join('');
        }

        // Render customer notifications
        function renderClientNotifications(notifs) {
            const list = document.getElementById('customer-notifications-list');
            if (notifs.length === 0) {
                list.innerHTML = `<p class="text-xs text-slate-500 text-center py-4">Aucune notification.</p>`;
                return;
            }

            list.innerHTML = notifs.map(n => `
                <div class="bg-slate-900/30 border border-slate-850/65 p-3 rounded-xl flex items-start space-x-2.5 ${n.isRead ? 'opacity-60' : 'border-l-2 border-l-primary-500 bg-primary-500/5'}">
                    <div class="mt-0.5 text-accent-gold">
                        <i data-lucide="${n.type === 'commission' ? 'coins' : 'bell'}" class="w-4 h-4"></i>
                    </div>
                    <div class="flex-grow">
                        <div class="flex justify-between items-center">
                            <h4 class="text-[11px] font-bold text-slate-200">${n.title}</h4>
                            <span class="text-[9px] text-slate-500">${formatDateIso(n.createdAt)}</span>
                        </div>
                        <p class="text-[10px] text-slate-400 mt-1 leading-relaxed">${n.message}</p>
                        ${!n.isRead ? `<button onclick="markNotificationRead(${n.id})" class="text-[9px] font-semibold text-primary-400 hover:text-white mt-1.5 transition">Marquer comme lu</button>` : ''}
                    </div>
                </div>
            `).join('');
            lucide.createIcons();
        }

        async function markNotificationRead(id) {
            try {
                await fetch(`/api/notifications/${id}/read`, {
                    method: 'PUT',
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                loadClientDashboard();
            } catch (err) {
                console.error(err);
            }
        }

        async function confirmOrderDelivery(id) {
            try {
                const res = await fetch(`/api/orders/${id}/confirm`, {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                const data = await res.json();
                if (data.status === 'success') {
                    showToast("Livraison confirmée", "Merci ! Votre confirmation a déclenché le calcul des commissions");
                    loadClientDashboard();
                } else {
                    showToast("Erreur", data.message || "Erreur de validation", true);
                }
            } catch (err) {
                console.error(err);
            }
        }

        function copyReferralCode() {
            const code = document.getElementById('wallet-referral-code').textContent;
            navigator.clipboard.writeText(code);
            showToast("Presse-papiers", "Code parrain copié !");
        }

        function formatDateIso(isoStr) {
            const d = new Date(isoStr);
            return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
        }

        // Toggle Admin/Client Portals
        let adminPortalOpen = false;
        function toggleAdminPortal() {
            const clientPortal = document.getElementById('client-portal-view');
            const adminPortal = document.getElementById('admin-portal-view');
            const btn = document.getElementById('admin-portal-btn');

            adminPortalOpen = !adminPortalOpen;
            if (adminPortalOpen) {
                clientPortal.classList.add('hidden');
                adminPortal.classList.remove('hidden');
                btn.innerHTML = `<i data-lucide="store" class="w-4 h-4"></i><span>Boutique</span>`;
                switchAdminTab(currentAdminTab);
            } else {
                adminPortal.classList.add('hidden');
                clientPortal.classList.remove('hidden');
                btn.innerHTML = `<i data-lucide="shield" class="w-4 h-4"></i><span>Espace Admin</span>`;
                loadClientDashboard();
            }
            lucide.createIcons();
        }

        // Helper to check API response status and handle session expiration (401)
        async function checkResponse(res) {
            if (res.status === 401) {
                showToast("Session expirée", "Votre session a expiré ou est invalide. Veuillez vous reconnecter.", true);
                handleLogout();
                openAuthModal();
                throw new Error("Unauthorized");
            }
            if (!res.ok) {
                const errorData = await res.json().catch(() => ({}));
                throw new Error(errorData.message || `Erreur serveur (code ${res.status})`);
            }
            return res.json();
        }

        // Switch admin tabs
        function switchAdminTab(tab) {
            currentAdminTab = tab;
            
            const tabs = ['dashboard', 'products', 'categories', 'users', 'stock'];
            tabs.forEach(t => {
                const btn = document.getElementById(`admin-tab-${t}`);
                const section = document.getElementById(`admin-section-${t}`);
                if (section) {
                    if (t === tab) {
                        if (btn) btn.className = "px-4 py-2 bg-primary-600 text-white text-xs font-semibold rounded-xl transition flex items-center justify-center space-x-2";
                        section.classList.remove('hidden');
                    } else {
                        if (btn) btn.className = "px-4 py-2 text-slate-400 hover:text-slate-200 text-xs font-semibold rounded-xl transition flex items-center justify-center space-x-2";
                        section.classList.add('hidden');
                    }
                }
            });

            if (tab === 'dashboard') {
                loadAdminPortalData();
            } else if (tab === 'products') {
                loadAdminProducts();
            } else if (tab === 'categories') {
                loadAdminCategories();
            } else if (tab === 'users') {
                loadAdminUsers();
            } else if (tab === 'stock') {
                loadAdminStockMovements();
            }
            lucide.createIcons();
        }

        // Load Admin Portal Dashboard Stats & Orders
        async function loadAdminPortalData() {
            if (!jwtToken) return;

            try {
                // 1. Dashboard stats
                const statRes = await fetch('/api/admin/dashboard', {
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                const stats = await checkResponse(statRes);

                document.getElementById('admin-stat-sales').textContent = numberWithSpaces(stats.totalSales) + " FC";
                document.getElementById('admin-stat-comm-gen').textContent = numberWithSpaces(stats.totalCommissionsGenerated) + " FC";
                document.getElementById('admin-stat-comm-paid').textContent = numberWithSpaces(stats.totalCommissionsPaid) + " FC";
                document.getElementById('admin-stat-orders').textContent = stats.totalOrders;
                document.getElementById('admin-stat-clients').textContent = stats.totalClients;

                // 2. Fetch all orders
                const ordersRes = await fetch('/api/admin/orders', {
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                const orders = await checkResponse(ordersRes);
                renderAdminOrders(orders);

            } catch (err) {
                console.error(err);
                if (err.message !== "Unauthorized") {
                    showToast("Erreur Admin", "Impossible de charger les données admin : " + err.message, true);
                }
            }
        }

        // PRODUCTS CRUD LOGIC
        async function loadAdminProducts() {
            try {
                const res = await fetch('/api/admin/products', {
                    headers: { 'Authorization': 'Bearer ' + jwtToken }
                });
                adminProducts = await checkResponse(res);
                renderAdminProductsTable();
            } catch (err) {
                console.error(err);
                if (err.message !== "Unauthorized") {
                    showToast("Erreur Admin", "Impossible de charger les produits : " + err.message, true);
                }
            }
        }

