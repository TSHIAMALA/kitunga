<!DOCTYPE html>
<html lang="fr" class="h-full bg-slate-900 text-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KITUNGA NA BISO - Commande & Parrainage</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        primary: {
                            50: '#edfaf4',
                            100: '#d4f2e3',
                            200: '#aee5cb',
                            300: '#7ad3ac',
                            400: '#3dbb86',
                            500: '#1da87b',
                            600: '#0f8962',
                            700: '#0d6e50',
                            800: '#0d5741',
                            900: '#0b4836',
                            950: '#06281e',
                        },
                        accent: {
                            gold: '#8b8c2a',
                            amber: '#b5b53e',
                        },
                        olive: {
                            400: '#b5b53e',
                            500: '#8b8c2a',
                            600: '#6e7024',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .glass {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(30, 41, 59, 0.5);
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(72, 139, 96, 0.4);
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(29, 168, 123, 0.6);
        }
        /* === Sidebar === */
        .sidebar {
            background: linear-gradient(180deg, #042a22 0%, #074a3b 35%, #0a5c47 70%, #0d6e50 100%);
            border-right: 1px solid rgba(255, 255, 255, 0.06);
        }
        .sidebar-section-header {
            display: flex; align-items: center; justify-content: space-between;
            width: 100%; padding: 10px 12px; font-size: 11px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.05em;
            color: rgba(255, 255, 255, 0.8); border-radius: 10px;
            transition: all 0.2s; cursor: pointer; background: transparent; border: none;
            font-family: 'Outfit', sans-serif;
        }
        .sidebar-section-header:hover { background: rgba(255, 255, 255, 0.05); }
        .sidebar-section-items { padding-left: 8px; }
        .sidebar-item {
            display: flex; align-items: center; gap: 10px; padding: 9px 12px;
            font-size: 13px; color: rgba(255, 255, 255, 0.55); border-radius: 8px;
            cursor: pointer; transition: all 0.2s; position: relative; text-decoration: none;
        }
        .sidebar-item:hover { color: rgba(255, 255, 255, 0.9); background: rgba(255, 255, 255, 0.05); }
        .sidebar-item.active { color: #fff; background: rgba(29, 168, 123, 0.2); }
        .sidebar-item .active-dot {
            width: 8px; height: 8px; border-radius: 50%; background: #1da87b; margin-left: auto;
        }
        .sidebar .logo-glow { filter: drop-shadow(0 0 20px rgba(29, 168, 123, 0.3)); }
        .sidebar .chevron-icon { transition: transform 0.3s ease; }
        .sidebar .chevron-icon.rotated { transform: rotate(180deg); }
        .sidebar-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 29;
            opacity: 0; pointer-events: none; transition: opacity 0.3s;
        }
        .sidebar-overlay.show { opacity: 1; pointer-events: auto; }
        .mobile-header {
            display: none; position: sticky; top: 0; z-index: 25;
            background: rgba(11, 18, 34, 0.95); backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding: 12px 16px;
        }
        @media (max-width: 1023px) {
            .sidebar { transform: translateX(-100%); transition: transform 0.3s ease; z-index: 30; }
            .sidebar.open { transform: translateX(0); }
            .mobile-header { display: flex; align-items: center; justify-content: space-between; }
        }
    </style>
</head>
<body class="min-h-screen font-sans custom-scrollbar bg-slate-900 text-slate-100">
    <!-- Toast Notification -->
    <div id="toast" class="fixed top-5 right-5 z-50 transform translate-x-80 transition-transform duration-300 ease-in-out glass rounded-xl p-4 flex items-center space-x-3 max-w-sm hidden shadow-2xl">
        <div id="toast-icon" class="p-2 rounded-lg bg-primary-500 text-white">
            <i data-lucide="check" class="w-5 h-5"></i>
        </div>
        <div>
            <h4 id="toast-title" class="font-semibold text-slate-100 text-sm">Notification</h4>
            <p id="toast-message" class="text-xs text-slate-400 mt-0.5">Message text.</p>
        </div>
    </div>

    <!-- Sidebar Overlay for mobile -->
    <div id="sidebar-overlay" class="sidebar-overlay" onclick="toggleMobileSidebar()"></div>

    <!-- Layout container -->
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside id="sidebar" class="sidebar fixed inset-y-0 left-0 w-64 lg:static lg:flex flex-col hidden lg:flex-shrink-0 z-30 transition-transform duration-300">
            <!-- Header of sidebar: Logo & Brand -->
            <div class="p-6 border-b border-white/5 flex flex-col items-center justify-center text-center">
                <div class="w-20 h-20 rounded-full bg-gradient-to-br from-kitunga-950/60 to-kitunga-900/30 flex items-center justify-center p-2 logo-glow mb-3">
                    <img src="/images/logo.png" alt="Logo" class="w-full h-full object-contain" onerror="this.style.display='none'; this.parentNode.innerHTML='<i data-lucide=\'cooking-pot\' class=\'w-10 h-10 text-kitunga-400\'></i>'; lucide.createIcons();">
                </div>
                <h1 class="text-lg font-extrabold text-white tracking-wider">KITUNGA NA BISO</h1>
                <p class="text-[9px] text-kitunga-300/60 uppercase tracking-widest font-semibold mt-0.5">Alimentation & Parrainage</p>
            </div>

            <!-- Login / Profile Button (Top Left of app layout) -->
            <div class="p-4 border-b border-white/5">
                <div id="sidebar-auth-section" class="space-y-2">
                    <button onclick="redirectToLogin()" class="w-full py-2 bg-primary-600 hover:bg-primary-500 text-white text-xs font-semibold rounded-xl transition flex items-center justify-center gap-2">
                        <i data-lucide="log-in" class="w-4 h-4"></i>
                        <span>Connexion</span>
                    </button>
                </div>
            </div>

            <!-- Navigation Links -->
            <div class="flex-grow p-4 space-y-4 overflow-y-auto custom-scrollbar">
                <!-- Section 1: Espace Boutique -->
                <div>
                    <button class="sidebar-section-header" onclick="toggleSidebarSection('shop-section')">
                        <span class="flex items-center gap-2">
                            <i data-lucide="store" class="w-4 h-4"></i>
                            <span>Boutique</span>
                        </span>
                        <i data-lucide="chevron-down" class="chevron-icon w-3.5 h-3.5" id="shop-section-chevron"></i>
                    </button>
                    <div id="shop-section" class="sidebar-section-items mt-1.5 space-y-1">
                        <a href="#" onclick="showSection('client-portal', 'menu-catalog'); filterCatalog(''); return false;" class="sidebar-item active" id="menu-catalog">
                            <i data-lucide="layout-grid" class="w-4 h-4"></i>
                            <span>Catalogue</span>
                            <span class="active-dot"></span>
                        </a>
                        <a href="#" onclick="showSection('client-portal', 'menu-cart'); toggleCartDrawer(); return false;" class="sidebar-item" id="menu-cart">
                            <i data-lucide="shopping-cart" class="w-4 h-4"></i>
                            <span>Panier</span>
                            <span id="cart-badge" class="bg-accent-amber text-slate-950 font-bold text-[9px] px-1.5 py-0.5 rounded-full ml-auto hidden">0</span>
                        </a>
                    </div>
                </div>

                <!-- Section 2: Mon Espace -->
                <div id="menu-section-member" class="hidden">
                    <button class="sidebar-section-header" onclick="toggleSidebarSection('member-section')">
                        <span class="flex items-center gap-2">
                            <i data-lucide="user" class="w-4 h-4"></i>
                            <span>Mon Espace</span>
                        </span>
                        <i data-lucide="chevron-down" class="chevron-icon w-3.5 h-3.5" id="member-section-chevron"></i>
                    </button>
                    <div id="member-section" class="sidebar-section-items mt-1.5 space-y-1">
                        <a href="#" onclick="scrollToElement('dashboard-wallet-card'); return false;" class="sidebar-item">
                            <i data-lucide="wallet" class="w-4 h-4"></i>
                            <span>Portefeuille</span>
                        </a>
                        <a href="#" onclick="scrollToElement('dashboard-orders-card'); return false;" class="sidebar-item">
                            <i data-lucide="package" class="w-4 h-4"></i>
                            <span>Mes Commandes</span>
                        </a>
                        <a href="#" onclick="scrollToElement('dashboard-notifications-card'); return false;" class="sidebar-item">
                            <i data-lucide="bell" class="w-4 h-4"></i>
                            <span>Notifications</span>
                        </a>
                    </div>
                </div>

                <!-- Section 4: Administration -->
                <div id="menu-section-admin" class="hidden">
                    <button class="sidebar-section-header" onclick="toggleSidebarSection('admin-section')">
                        <span class="flex items-center gap-2">
                            <i data-lucide="shield" class="w-4 h-4"></i>
                            <span>Administration</span>
                        </span>
                        <i data-lucide="chevron-down" class="chevron-icon w-3.5 h-3.5" id="admin-section-chevron"></i>
                    </button>
                    <div id="admin-section" class="sidebar-section-items mt-1.5 space-y-1">
                        <a href="#" onclick="showSection('admin-portal', 'menu-admin-dashboard'); switchAdminTab('dashboard'); return false;" class="sidebar-item" id="menu-admin-dashboard">
                            <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
                            <span>Tableau de bord</span>
                        </a>
                        <a href="#" onclick="showSection('admin-portal', 'menu-admin-products'); switchAdminTab('products'); return false;" class="sidebar-item" id="menu-admin-products">
                            <i data-lucide="package" class="w-4 h-4"></i>
                            <span>Produits</span>
                        </a>
                        <a href="#" onclick="showSection('admin-portal', 'menu-admin-categories'); switchAdminTab('categories'); return false;" class="sidebar-item" id="menu-admin-categories">
                            <i data-lucide="tags" class="w-4 h-4"></i>
                            <span>Catégories</span>
                        </a>
                        <a href="#" onclick="showSection('admin-portal', 'menu-admin-users'); switchAdminTab('users'); return false;" class="sidebar-item" id="menu-admin-users">
                            <i data-lucide="users" class="w-4 h-4"></i>
                            <span>Utilisateurs</span>
                        </a>
                        <a href="#" onclick="showSection('admin-portal', 'menu-admin-stock'); switchAdminTab('stock'); return false;" class="sidebar-item" id="menu-admin-stock">
                            <i data-lucide="clipboard-list" class="w-4 h-4"></i>
                            <span>Mouvements Stock</span>
                        </a>
                    </div>
                </div>
            </div>


        </aside>

        <!-- Right Side Content Area -->
        <div class="flex-1 flex flex-col min-h-screen overflow-x-hidden">
            
            <!-- Mobile Header -->
            <header class="mobile-header">
                <button onclick="toggleMobileSidebar()" class="p-2 text-slate-300 hover:text-white transition">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <span class="text-sm font-bold text-white tracking-wider flex items-center gap-2">
                    <i data-lucide="cooking-pot" class="w-5 h-5 text-kitunga-400"></i>
                    KITUNGA
                </span>
                <button onclick="toggleCartDrawer()" class="relative p-2 text-slate-300 hover:text-white transition">
                    <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                    <span id="cart-badge-mobile" class="absolute -top-1 -right-1 bg-accent-amber text-slate-950 font-bold text-[8px] w-4 h-4 flex items-center justify-center rounded-full hidden">0</span>
                </button>
            </header>

            <!-- Main Content Container -->
            <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col space-y-8">
        

        <!-- Client Portal View -->
        <div id="client-portal-view" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Catalog Section -->
            <div class="lg:col-span-2 space-y-6">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="text-xl font-extrabold text-slate-100 flex items-center space-x-2">
                            <i data-lucide="store" class="w-5.5 h-5.5 text-primary-400"></i>
                            <span>Catalogue Produits Alimentaires</span>
                        </h2>
                        <p class="text-xs text-slate-400 mt-1">Sélection de produits alimentaires commercialisés par KITUNGA NA BISO.</p>
                    </div>
                    <!-- Categories filters -->
                    <div class="flex space-x-2 bg-slate-850 p-1 rounded-xl border border-slate-800">
                        <button onclick="filterCatalog('')" id="cat-all" class="px-3 py-1.5 bg-primary-600 text-white text-xs font-semibold rounded-lg transition">Tous</button>
                        <button onclick="filterCatalog('Poissons')" id="cat-poissons" class="px-3 py-1.5 text-slate-400 hover:text-white text-xs font-semibold rounded-lg transition">Poissons</button>
                        <button onclick="filterCatalog('Féculents')" id="cat-feculents" class="px-3 py-1.5 text-slate-400 hover:text-white text-xs font-semibold rounded-lg transition">Féculents</button>
                    </div>
                </div>

                <!-- Products Grid -->
                <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <!-- Loaded dynamically -->
                    <div class="col-span-full py-12 flex flex-col items-center justify-center text-slate-500">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500"></div>
                        <p class="text-xs mt-3">Chargement des produits...</p>
                    </div>
                </div>
            </div>

            <!-- Customer Dashboard / Right Panel -->
            <div class="space-y-8">
                <!-- Wallet Card (Auth required) -->
                <div id="dashboard-wallet-card" class="glass rounded-3xl p-6 shadow-xl relative overflow-hidden hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-primary-500/10 rounded-full blur-2xl pointer-events-none"></div>
                    <div class="flex justify-between items-start">
                        <div>
                            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Portefeuille Commissions</span>
                            <h3 id="wallet-client-name" class="font-bold text-slate-100 text-base mt-0.5">Client</h3>
                        </div>
                        <span class="bg-primary-500/15 text-primary-400 text-[10px] px-2.5 py-1 rounded-full font-bold uppercase tracking-wider">Solde Actif</span>
                    </div>

                    <!-- Balance Display -->
                    <div class="mt-6">
                        <p class="text-3xl font-extrabold tracking-tight text-white"><span id="wallet-balance">0</span> <span class="text-sm font-semibold text-slate-400">FC</span></p>
                        <p class="text-[11px] text-slate-400 mt-1">Disponible pour retrait mobile money ou cash.</p>
                    </div>

                    <!-- Cumulative values -->
                    <div class="grid grid-cols-2 gap-4 border-t border-slate-800/80 pt-4 mt-6">
                        <div>
                            <span class="text-[10px] text-slate-400 uppercase font-semibold">Total Généré</span>
                            <p id="wallet-total-generated" class="text-sm font-bold text-slate-200 mt-0.5">0 FC</p>
                        </div>
                        <div>
                            <span class="text-[10px] text-slate-400 uppercase font-semibold">Total Payé</span>
                            <p id="wallet-total-paid" class="text-sm font-bold text-slate-200 mt-0.5">0 FC</p>
                        </div>
                    </div>

                    <!-- Referral code info -->
                    <div class="bg-slate-900/60 rounded-2xl p-3.5 border border-slate-800/80 mt-5 flex items-center justify-between">
                        <div>
                            <span class="text-[10px] text-slate-400 uppercase font-semibold">Votre Code Parrain</span>
                            <p id="wallet-referral-code" class="text-sm font-extrabold text-accent-gold mt-0.5">---</p>
                        </div>
                        <button onclick="copyReferralCode()" class="p-2 bg-slate-800 hover:bg-slate-750 text-slate-400 hover:text-white rounded-lg transition">
                            <i data-lucide="copy" class="w-4 h-4"></i>
                        </button>
                    </div>

                    <!-- Downline Count Stats -->
                    <div class="grid grid-cols-2 gap-3 mt-4 text-center">
                        <div class="bg-slate-900/40 rounded-xl p-2.5 border border-slate-850">
                            <span id="wallet-direct-count" class="text-lg font-bold text-slate-200 block">0</span>
                            <span class="text-[9px] text-slate-500 uppercase font-semibold">Filleuls Directs</span>
                        </div>
                        <div class="bg-slate-900/40 rounded-xl p-2.5 border border-slate-850">
                            <span id="wallet-indirect-count" class="text-lg font-bold text-slate-200 block">0</span>
                            <span class="text-[9px] text-slate-500 uppercase font-semibold">Filleuls Indirects</span>
                        </div>
                    </div>
                </div>

                <!-- Active Sessions Actions / Orders List -->
                <div id="dashboard-orders-card" class="glass rounded-3xl p-6 shadow-xl hidden">
                    <h3 class="text-sm font-bold text-slate-200 flex items-center space-x-2 border-b border-slate-800 pb-3">
                        <i data-lucide="package" class="w-4.5 h-4.5 text-primary-400"></i>
                        <span>Mes Commandes Récentes</span>
                    </h3>
                    <div id="customer-orders-list" class="mt-4 space-y-3 max-h-60 overflow-y-auto custom-scrollbar pr-1">
                        <!-- Loaded dynamically -->
                        <p class="text-xs text-slate-500 text-center py-4">Aucune commande enregistrée.</p>
                    </div>
                </div>

                <!-- Notifications Panel -->
                <div id="dashboard-notifications-card" class="glass rounded-3xl p-6 shadow-xl hidden">
                    <h3 class="text-sm font-bold text-slate-200 flex items-center space-x-2 border-b border-slate-800 pb-3">
                        <i data-lucide="bell" class="w-4.5 h-4.5 text-accent-amber"></i>
                        <span>Notifications</span>
                    </h3>
                    <div id="customer-notifications-list" class="mt-4 space-y-3 max-h-56 overflow-y-auto custom-scrollbar pr-1">
                        <!-- Loaded dynamically -->
                        <p class="text-xs text-slate-500 text-center py-4">Aucune notification.</p>
                    </div>
                </div>

                <!-- Promo parrainage card -->
                <div class="bg-gradient-to-tr from-primary-950 via-primary-900 to-slate-900 rounded-3xl p-6 shadow-xl border border-primary-500/25 relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-accent-gold/10 rounded-full blur-xl pointer-events-none"></div>
                    <h3 class="text-base font-extrabold text-white flex items-center space-x-2">
                        <i data-lucide="users" class="w-5 h-5 text-accent-gold"></i>
                        <span>Parrainage KITUNGA multiniveau</span>
                    </h3>
                    <ul class="text-xs text-slate-300 mt-4 space-y-3 leading-relaxed">
                        <li class="flex items-start space-x-2">
                            <span class="text-accent-gold font-bold">5%</span>
                            <span>sur chaque achat de votre filleul direct (Niveau 1).</span>
                        </li>
                        <li class="flex items-start space-x-2">
                            <span class="text-accent-gold font-bold">2%</span>
                            <span>sur chaque achat du filleul de votre filleul (Niveau 2).</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Administration Portal View -->
        <!-- Administration Portal View -->
        <div id="admin-portal-view" class="space-y-8 hidden">
            <div class="flex items-center justify-between border-b border-slate-800 pb-4">
                <div>
                    <h2 class="text-xl font-extrabold text-slate-100 flex items-center space-x-2">
                        <i data-lucide="shield-check" class="w-6 h-6 text-accent-amber"></i>
                        <span>Portail d'Administration KITUNGA NA BISO</span>
                    </h2>
                    <p class="text-xs text-slate-400 mt-1">Vue consolidée du réseau de vente, gestion des livreurs, décaissements de commissions et catalogue.</p>
                </div>
                <button onclick="toggleAdminPortal()" class="px-3.5 py-1.5 bg-slate-800 hover:bg-slate-750 text-slate-300 text-xs font-semibold rounded-lg transition border border-slate-700/60">
                    Retour Boutique
                </button>
            </div>



            <!-- SECTION 1: DASHBOARD & ORDERS -->
            <div id="admin-section-dashboard" class="space-y-8">
                <!-- Admin Key Stats Row -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
                    <div class="glass rounded-2xl p-5 shadow-lg">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Chiffre d'Affaires</span>
                        <span id="admin-stat-sales" class="text-2xl font-black text-white mt-2 block">0 FC</span>
                    </div>
                    <div class="glass rounded-2xl p-5 shadow-lg">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Commissions Générées</span>
                        <span id="admin-stat-comm-gen" class="text-2xl font-black text-primary-400 mt-2 block">0 FC</span>
                    </div>
                    <div class="glass rounded-2xl p-5 shadow-lg">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Commissions Payées</span>
                        <span id="admin-stat-comm-paid" class="text-2xl font-black text-slate-300 mt-2 block">0 FC</span>
                    </div>
                    <div class="glass rounded-2xl p-5 shadow-lg">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Total Commandes</span>
                        <span id="admin-stat-orders" class="text-2xl font-black text-accent-amber mt-2 block">0</span>
                    </div>
                    <div class="glass rounded-2xl p-5 shadow-lg">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Total Clients</span>
                        <span id="admin-stat-clients" class="text-2xl font-black text-slate-100 mt-2 block">0</span>
                    </div>
                </div>

                <!-- Orders Management Table & Actions -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <!-- Orders -->
                    <div class="lg:col-span-2 glass rounded-3xl p-6 shadow-xl">
                        <h3 class="text-sm font-bold text-slate-200 flex items-center space-x-2 border-b border-slate-800 pb-3 mb-4">
                            <i data-lucide="package-open" class="w-4.5 h-4.5 text-accent-amber"></i>
                            <span>Suivi des Commandes Clients</span>
                        </h3>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-xs border-collapse">
                                <thead>
                                    <tr class="text-[10px] uppercase font-bold text-slate-500 border-b border-slate-800/80">
                                        <th class="py-2.5">ID</th>
                                        <th class="py-2.5">Client</th>
