                                </button>
                                <button onclick="toggleUserStatus(${u.id}, '${toggleStatusAction}')" class="px-2 py-1 ${toggleStatusBtnColor} rounded-lg text-[11px] font-semibold transition inline-flex items-center gap-1" title="${toggleStatusText}">
                                    <i data-lucide="${toggleStatusIcon}" class="w-3 h-3"></i><span>${toggleStatusText}</span>
