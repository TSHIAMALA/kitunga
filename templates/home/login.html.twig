<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KITUNGA NA BISO - Connexion</title>
    <meta name="description" content="Connectez-vous à KITUNGA NA BISO - Plateforme de commande alimentaire et parrainage multiniveau en RDC.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        kitunga: {
                            50: '#edfaf4',
                            100: '#d4f2e3',
                            200: '#aee5cb',
                            300: '#7ad3ac',
                            400: '#3dbb86',
                            500: '#1da87b',
                            600: '#0f8962',
                            700: '#0d6e50',
                            800: '#0d5741',
                            900: '#0b4836',
                            950: '#06281e',
                        },
                        olive: {
                            400: '#b5b53e',
                            500: '#8b8c2a',
                            600: '#6e7024',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        .login-left-panel {
            background: linear-gradient(155deg, #042a22 0%, #074a3b 35%, #0a5c47 60%, #0d6e50 100%);
            position: relative;
        }

        .login-left-panel::before {
            content: '';
            position: absolute;
            top: -20%;
            right: -30%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(29, 168, 123, 0.12) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .login-left-panel::after {
            content: '';
            position: absolute;
            bottom: -15%;
            left: -20%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(139, 140, 42, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .glass-card {
            background: rgba(6, 40, 30, 0.55);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
        }

        .glass-card-form {
            background: rgba(15, 25, 40, 0.65);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 20px;
        }

        .login-right-panel {
            background: linear-gradient(170deg, #0B1222 0%, #0e1729 50%, #111d33 100%);
            position: relative;
        }

        .login-right-panel::before {
            content: '';
            position: absolute;
            top: 15%;
            left: -10%;
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, rgba(29, 168, 123, 0.06) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .login-input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(15, 25, 40, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            color: #e2e8f0;
            font-size: 14px;
            font-family: 'Outfit', sans-serif;
            transition: all 0.3s ease;
            outline: none;
        }

        .login-input::placeholder {
            color: rgba(148, 163, 184, 0.5);
        }

        .login-input:focus {
            border-color: rgba(29, 168, 123, 0.5);
            box-shadow: 0 0 0 3px rgba(29, 168, 123, 0.1);
        }

        .btn-login {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #0f8962, #1da87b);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 14px;
            font-weight: 600;
            font-family: 'Outfit', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-login:hover {
            background: linear-gradient(135deg, #1da87b, #3dbb86);
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(29, 168, 123, 0.25);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .btn-login:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 10px 0;
        }

        .feature-icon {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .logo-glow {
            filter: drop-shadow(0 0 20px rgba(29, 168, 123, 0.3));
        }

        /* Entrance animations */
        @keyframes slideInLeft {
            from { opacity: 0; transform: translateX(-40px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(40px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-slide-left {
            animation: slideInLeft 0.8s ease-out forwards;
        }

        .animate-slide-right {
            animation: slideInRight 0.8s ease-out forwards;
        }

        .animate-fade-up {
            animation: fadeInUp 0.6s ease-out forwards;
        }

        .animate-delay-1 { animation-delay: 0.1s; opacity: 0; }
        .animate-delay-2 { animation-delay: 0.2s; opacity: 0; }
        .animate-delay-3 { animation-delay: 0.3s; opacity: 0; }
        .animate-delay-4 { animation-delay: 0.4s; opacity: 0; }
        .animate-delay-5 { animation-delay: 0.5s; opacity: 0; }

        /* Toast notification */
        .toast-container {
            position: fixed;
            top: 24px;
            right: 24px;
            z-index: 100;
            transform: translateX(120%);
            transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .toast-container.show {
            transform: translateX(0);
        }

        /* Checkbox custom */
        .custom-checkbox {
            appearance: none;
            width: 16px;
            height: 16px;
            border: 1.5px solid rgba(255, 255, 255, 0.15);
            border-radius: 4px;
            background: rgba(15, 25, 40, 0.6);
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

        .custom-checkbox:checked {
            background: #1da87b;
            border-color: #1da87b;
        }

        .custom-checkbox:checked::after {
            content: '✓';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            font-size: 10px;
            font-weight: 700;
        }

        /* Spinner */
        .spinner {
            width: 18px;
            height: 18px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Register form transition */
        .form-panel {
            transition: opacity 0.3s ease, transform 0.3s ease;
        }

        .form-panel.hidden-form {
            opacity: 0;
            transform: translateY(10px);
            position: absolute;
            pointer-events: none;
        }
    </style>
</head>
<body class="h-full font-sans">
    <!-- Toast -->
    <div id="login-toast" class="toast-container">
        <div class="glass-card-form py-3 px-4 flex items-center gap-3 min-w-[300px] shadow-2xl">
            <div id="toast-icon-wrap" class="w-8 h-8 rounded-lg bg-red-500/20 flex items-center justify-center">
                <i data-lucide="alert-circle" class="w-4 h-4 text-red-400"></i>
            </div>
            <div>
                <p id="toast-title" class="text-sm font-semibold text-white">Erreur</p>
                <p id="toast-msg" class="text-xs text-slate-400 mt-0.5">Message</p>
            </div>
        </div>
    </div>

    <!-- Main Split Layout -->
    <div class="flex min-h-screen">
        
        <!-- ===== LEFT PANEL ===== -->
        <div class="hidden lg:flex w-[48%] login-left-panel flex-col items-center justify-center px-12 relative overflow-hidden">
            
            <!-- Decorative floating shapes -->
            <div class="absolute top-[10%] right-[15%] w-20 h-20 border border-white/5 rounded-full animate-pulse"></div>
            <div class="absolute bottom-[20%] left-[10%] w-14 h-14 border border-kitunga-500/10 rounded-2xl rotate-45"></div>
            <div class="absolute top-[60%] right-[8%] w-8 h-8 bg-kitunga-500/5 rounded-full"></div>

            <!-- Glass Card with Logo -->
            <div class="glass-card px-12 py-10 flex flex-col items-center text-center animate-slide-left relative z-10">
                <div class="w-36 h-36 rounded-full bg-gradient-to-br from-kitunga-950/50 to-kitunga-900/30 flex items-center justify-center p-3 mb-5 logo-glow">
                    <img src="/images/logo.png" alt="Kitunga Na Biso" class="w-full h-full object-contain" onerror="this.style.display='none'; this.parentNode.innerHTML='<i data-lucide=\'cooking-pot\' class=\'w-16 h-16 text-kitunga-400\'></i>'; lucide.createIcons();">
                </div>
                <h1 class="text-3xl font-extrabold text-white tracking-wider">KITUNGA</h1>
                <span class="text-xl font-bold bg-gradient-to-r from-olive-400 to-kitunga-400 bg-clip-text text-transparent mt-0.5">NA BISO</span>
                <p class="text-sm text-kitunga-300/60 mt-3 tracking-wide">Commande & Parrainage Alimentaire</p>
            </div>

            <!-- Feature Points -->
            <div class="mt-12 space-y-1 w-full max-w-xs relative z-10">
                <div class="feature-item animate-fade-up animate-delay-2">
                    <div class="feature-icon bg-kitunga-500/15">
                        <i data-lucide="truck" class="w-4.5 h-4.5 text-kitunga-400"></i>
                    </div>
                    <span class="text-sm text-kitunga-200/80 font-medium">Livraison rapide à Kinshasa</span>
                </div>
                <div class="feature-item animate-fade-up animate-delay-3">
                    <div class="feature-icon bg-olive-500/15">
                        <i data-lucide="users" class="w-4.5 h-4.5 text-olive-400"></i>
                    </div>
                    <span class="text-sm text-kitunga-200/80 font-medium">Commissions multiniveau 5% & 2%</span>
                </div>
                <div class="feature-item animate-fade-up animate-delay-4">
                    <div class="feature-icon bg-kitunga-500/15">
                        <i data-lucide="shield-check" class="w-4.5 h-4.5 text-kitunga-400"></i>
                    </div>
                    <span class="text-sm text-kitunga-200/80 font-medium">Sécurisé et fiable</span>
                </div>
            </div>
        </div>

        <!-- ===== RIGHT PANEL ===== -->
        <div class="flex-1 login-right-panel flex flex-col items-center justify-center px-6 sm:px-12 relative">

            <!-- Mobile Logo (visible on small screens only) -->
            <div class="lg:hidden flex flex-col items-center mb-8">
                <div class="w-20 h-20 rounded-full bg-gradient-to-br from-kitunga-950/60 to-kitunga-900/30 flex items-center justify-center p-2 logo-glow mb-3">
                    <img src="/images/logo.png" alt="Logo" class="w-full h-full object-contain" onerror="this.style.display='none'; this.parentNode.innerHTML='<i data-lucide=\'cooking-pot\' class=\'w-10 h-10 text-kitunga-400\'></i>'; lucide.createIcons();">
                </div>
                <h1 class="text-xl font-extrabold text-white tracking-wider">KITUNGA <span class="bg-gradient-to-r from-olive-400 to-kitunga-400 bg-clip-text text-transparent">NA BISO</span></h1>
            </div>

            <!-- Form Container -->
            <div class="glass-card-form w-full max-w-md px-8 py-10 animate-slide-right relative" id="form-container">
                
                <!-- Login Form -->
                <div id="panel-login" class="form-panel">
                    <h2 class="text-2xl font-bold text-white text-center">Bienvenue</h2>
                    <p class="text-sm text-slate-400 text-center mt-1.5">Connectez-vous à votre espace</p>

                    <form id="login-form" class="mt-8 space-y-5" autocomplete="on">
                        <!-- Email -->
                        <div>
                            <label class="flex items-center gap-2 text-sm text-slate-300 font-medium mb-2">
                                <i data-lucide="mail" class="w-4 h-4 text-kitunga-400"></i>
                                Adresse email
                            </label>
                            <input type="email" id="login-email" name="email" required autocomplete="email"
                                placeholder="votre.email@exemple.com" class="login-input">
                        </div>

                        <!-- Password -->
                        <div>
                            <label class="flex items-center gap-2 text-sm text-slate-300 font-medium mb-2">
                                <i data-lucide="lock" class="w-4 h-4 text-olive-400"></i>
                                Mot de passe
                            </label>
                            <input type="password" id="login-password" name="password" required autocomplete="current-password"
                                placeholder="••••••••" class="login-input">
                        </div>

                        <!-- Remember + Forgot -->
                        <div class="flex items-center justify-between">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" id="remember-me" class="custom-checkbox">
                                <span class="text-sm text-slate-400">Se souvenir de moi</span>
                            </label>
                            <a href="#" class="text-sm text-kitunga-400 hover:text-kitunga-300 transition font-medium">Mot de passe oublié?</a>
                        </div>

                        <!-- Login Error -->
                        <div id="login-error" class="hidden bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-sm text-red-400 flex items-center gap-2">
                            <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
                            <span id="login-error-msg">Identifiants incorrects</span>
                        </div>

                        <!-- Submit -->
                        <button type="submit" id="btn-login" class="btn-login">
                            <i data-lucide="log-in" class="w-4.5 h-4.5"></i>
                            <span>Se connecter</span>
                        </button>
                    </form>

                    <!-- Register link -->
                    <p class="text-center text-sm text-slate-400 mt-6">
                        Pas encore de compte?
                        <a href="#" onclick="switchToRegister(event)" class="text-kitunga-400 hover:text-kitunga-300 font-semibold transition ml-1">S'inscrire</a>
                    </p>
                </div>

                <!-- Register Form -->
                <div id="panel-register" class="form-panel hidden-form">
                    <h2 class="text-2xl font-bold text-white text-center">Créer un compte</h2>
                    <p class="text-sm text-slate-400 text-center mt-1.5">Rejoignez le réseau KITUNGA NA BISO</p>

                    <form id="register-form" class="mt-7 space-y-4" autocomplete="on">
                        <div>
                            <label class="flex items-center gap-2 text-sm text-slate-300 font-medium mb-1.5">
                                <i data-lucide="user" class="w-4 h-4 text-kitunga-400"></i>
                                Nom complet
                            </label>
                            <input type="text" id="reg-name" required placeholder="Ex: Trésor Mufuta" class="login-input">
                        </div>
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="flex items-center gap-2 text-sm text-slate-300 font-medium mb-1.5">
                                    <i data-lucide="mail" class="w-3.5 h-3.5 text-kitunga-400"></i>
                                    Email
                                </label>
                                <input type="email" id="reg-email" required placeholder="email@exemple.com" class="login-input">
                            </div>
                            <div>
                                <label class="flex items-center gap-2 text-sm text-slate-300 font-medium mb-1.5">
                                    <i data-lucide="phone" class="w-3.5 h-3.5 text-kitunga-400"></i>
                                    Téléphone
                                </label>
                                <input type="text" id="reg-phone" required placeholder="+24381234567" class="login-input">
                            </div>
                        </div>
                        <div>
                            <label class="flex items-center gap-2 text-sm text-slate-300 font-medium mb-1.5">
                                <i data-lucide="lock" class="w-4 h-4 text-olive-400"></i>
                                Mot de passe (min. 6 car.)
                            </label>
                            <input type="password" id="reg-password" required minlength="6" class="login-input">
                        </div>
                        <div>
                            <label class="flex items-center gap-2 text-sm text-slate-300 font-medium mb-1.5">
                                <i data-lucide="gift" class="w-4 h-4 text-olive-400"></i>
                                Code Parrain (facultatif)
                            </label>
                            <input type="text" id="reg-referrer" placeholder="Ex: KNB-XX1234" class="login-input">
                        </div>

                        <!-- Register Error -->
                        <div id="register-error" class="hidden bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-sm text-red-400 flex items-center gap-2">
                            <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
                            <span id="register-error-msg">Erreur</span>
                        </div>

                        <!-- Register Success -->
                        <div id="register-success" class="hidden bg-kitunga-500/10 border border-kitunga-500/20 rounded-xl px-4 py-3 text-sm text-kitunga-400 flex items-center gap-2">
                            <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
                            <span id="register-success-msg">Inscription réussie!</span>
                        </div>

                        <button type="submit" id="btn-register" class="btn-login mt-2">
                            <i data-lucide="user-plus" class="w-4.5 h-4.5"></i>
                            <span>S'inscrire et obtenir mon code</span>
                        </button>
                    </form>

                    <p class="text-center text-sm text-slate-400 mt-6">
                        Déjà un compte?
                        <a href="#" onclick="switchToLogin(event)" class="text-kitunga-400 hover:text-kitunga-300 font-semibold transition ml-1">Se connecter</a>
                    </p>
                </div>
            </div>

            <!-- Footer -->
            <p class="absolute bottom-6 text-center text-xs text-slate-500/60">
                © 2026 Kitunga Na Biso. Tous droits réservés.
            </p>
        </div>
    </div>

    <script>
        // Init icons
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();

            // If already logged in, redirect to dashboard
            const token = localStorage.getItem('jwt_token');
            const user = localStorage.getItem('current_user');
            if (token && user) {
                window.location.href = '/';
            }
        });

        // Toast helper
        function showLoginToast(title, message, isError = true) {
            const toast = document.getElementById('login-toast');
            const iconWrap = document.getElementById('toast-icon-wrap');
            document.getElementById('toast-title').textContent = title;
            document.getElementById('toast-msg').textContent = message;

            if (isError) {
                iconWrap.className = 'w-8 h-8 rounded-lg bg-red-500/20 flex items-center justify-center';
                iconWrap.innerHTML = '<i data-lucide="alert-circle" class="w-4 h-4 text-red-400"></i>';
            } else {
                iconWrap.className = 'w-8 h-8 rounded-lg bg-kitunga-500/20 flex items-center justify-center';
                iconWrap.innerHTML = '<i data-lucide="check-circle" class="w-4 h-4 text-kitunga-400"></i>';
            }
            lucide.createIcons();

            toast.classList.add('show');
            setTimeout(() => {
                toast.classList.remove('show');
            }, 4000);
        }

        // Switch between Login and Register
        function switchToRegister(e) {
            e.preventDefault();
            document.getElementById('panel-login').classList.add('hidden-form');
            document.getElementById('panel-register').classList.remove('hidden-form');
        }

        function switchToLogin(e) {
            e.preventDefault();
            document.getElementById('panel-register').classList.add('hidden-form');
            document.getElementById('panel-login').classList.remove('hidden-form');
        }

        // Handle Login
        document.getElementById('login-form').addEventListener('submit', async (e) => {
            e.preventDefault();

            const email = document.getElementById('login-email').value.trim();
            const password = document.getElementById('login-password').value;
            const btn = document.getElementById('btn-login');
            const errorDiv = document.getElementById('login-error');
            const errorMsg = document.getElementById('login-error-msg');

            // Hide previous error
            errorDiv.classList.add('hidden');

            // Loading state
            btn.disabled = true;
            btn.innerHTML = '<div class="spinner"></div> <span>Connexion en cours...</span>';

            try {
                const res = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });

                if (res.status === 200) {
                    const data = await res.json();
                    localStorage.setItem('jwt_token', data.token);

                    // Decode JWT payload
                    const payload = JSON.parse(atob(data.token.split('.')[1]));
                    const currentUser = {
                        email: payload.username,
                        roles: payload.roles || []
                    };
                    localStorage.setItem('current_user', JSON.stringify(currentUser));

                    showLoginToast('Connexion réussie', 'Redirection vers votre espace...', false);

                    // Redirect after short delay
                    setTimeout(() => {
                        window.location.href = '/';
                    }, 800);
                } else {
                    errorMsg.textContent = 'Adresse email ou mot de passe incorrect.';
                    errorDiv.classList.remove('hidden');
                    lucide.createIcons();

                    btn.disabled = false;
                    btn.innerHTML = '<i data-lucide="log-in" class="w-4.5 h-4.5"></i> <span>Se connecter</span>';
                    lucide.createIcons();
                }
            } catch (err) {
                console.error(err);
                errorMsg.textContent = 'Erreur de communication avec le serveur.';
                errorDiv.classList.remove('hidden');
                lucide.createIcons();

                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="log-in" class="w-4.5 h-4.5"></i> <span>Se connecter</span>';
                lucide.createIcons();
            }
        });

        // Handle Register
        document.getElementById('register-form').addEventListener('submit', async (e) => {
            e.preventDefault();

            const fullName = document.getElementById('reg-name').value.trim();
            const email = document.getElementById('reg-email').value.trim();
            const phone = document.getElementById('reg-phone').value.trim();
            const password = document.getElementById('reg-password').value;
            const referrerCode = document.getElementById('reg-referrer').value.trim();
            const btn = document.getElementById('btn-register');
            const errorDiv = document.getElementById('register-error');
            const errorMsgEl = document.getElementById('register-error-msg');
            const successDiv = document.getElementById('register-success');
            const successMsgEl = document.getElementById('register-success-msg');

            errorDiv.classList.add('hidden');
            successDiv.classList.add('hidden');

            btn.disabled = true;
            btn.innerHTML = '<div class="spinner"></div> <span>Inscription en cours...</span>';

            try {
                const res = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName, email, phone, password, referrerCode: referrerCode || undefined })
                });

                const data = await res.json();

                if (res.status === 201) {
                    successMsgEl.textContent = `Inscription réussie! Votre code: ${data.user.referralCode}`;
                    successDiv.classList.remove('hidden');
                    lucide.createIcons();

                    showLoginToast('Bienvenue!', 'Compte créé avec succès', false);

                    // Switch to login after delay with prefilled email
                    setTimeout(() => {
                        switchToLogin(new Event('click'));
                        document.getElementById('login-email').value = email;
                    }, 2000);
                } else {
                    let errMsg = "Erreur lors de l'inscription";
                    if (data.errors) {
                        errMsg = Object.values(data.errors).join(', ');
                    }
                    errorMsgEl.textContent = errMsg;
                    errorDiv.classList.remove('hidden');
                    lucide.createIcons();
                }
            } catch (err) {
                console.error(err);
                errorMsgEl.textContent = 'Erreur réseau. Veuillez réessayer.';
                errorDiv.classList.remove('hidden');
                lucide.createIcons();
            }

            btn.disabled = false;
            btn.innerHTML = '<i data-lucide="user-plus" class="w-4.5 h-4.5"></i> <span>S\'inscrire et obtenir mon code</span>';
            lucide.createIcons();
        });
    </script>
</body>
</html>
